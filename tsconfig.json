{
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "functions/**/*.ts",
    "scripts/**/*.ts",
    "*.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": { "~/*": ["./app/*"] }
  }
}
